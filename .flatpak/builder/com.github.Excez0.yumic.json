{
  "app-id": "com.github.Excez0.yumic",
  "runtime": "org.gnome.Platform",
  "runtime-version": "47",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions": ["org.freedesktop.Sdk.Extension.rust-stable"],
  "command": "yumic-server",
  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=pulseaudio",
    "--socket=wayland",
    "--socket=fallback-x11",
    "--device=all",
    "--talk-name=org.freedesktop.portal.Desktop",
    "--talk-name=org.freedesktop.portal.Request",
    "--filesystem=~/.config/yumic:rw",
    "--filesystem=/tmp/yumic_audio_pipe:rw"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin",
    "env": {
      "CARGO_HOME": "/run/build/yumic-server/cargo"
    }
  },
  "modules": [
    {
      "name": "yumic-server",
      "buildsystem": "simple",
      "build-commands": [
        "cargo --offline build --release --locked",
        "install -Dm755 target/release/yumic-server /app/bin/yumic-server",
        "install -Dm644 assets/yumic.desktop /app/share/applications/com.github.Excez0.yumic.desktop",
        "install -Dm644 assets/yumic.svg /app/share/icons/hicolor/scalable/apps/com.github.Excez0.yumic.svg"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/Excez0/yumic-server.git",
          "tag": "v1.0.8"
        },
        "cargo-sources.json"
      ]
    }
  ]
}